<nav class="pp-scheme-switcher" aria-label="Color scheme">
    {% set scheme_labels = {
        auto: 'System',
        light: 'Light',
        dark: 'Dark',
    } %}
    {% for link in schemeSwitcherLinks %}
        <a
            href="{{ link.url }}"
            class="pp-scheme-switcher__btn{% if link.active %} is-active{% endif %}"
            {% if link.active %}aria-current="true"{% endif %}
        >{{ scheme_labels[link.scheme]|default(link.scheme) }}</a>
    {% endfor %}
</nav>

                <twig:SchemeSwitch
                    scheme="{{ scheme }}"
                    :links="schemeSwitcherLinks"
                    schemeEndpoint="{{ schemeEndpoint }}"
                />
