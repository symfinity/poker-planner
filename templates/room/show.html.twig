{% extends '@SymfinityPokerPlanner/base.html.twig' %}

{% block title %}Poker Planner — quick room{% endblock %}

{% block shell_bar %}{% endblock %}

{% block head %}
    {{ parent() }}
    {{ turbo_stream_from(mercure_topic) }}
{% endblock %}

{% block body %}
{% set shareUrl = url('poker_planner_room', {uuid: room.id}) %}

<main
    class="pp-room"
    id="poker-room"
    data-moderator="{{ self.isModerator ? '1' : '0' }}"
    data-self-participant-id="{{ self.id }}"
    data-heartbeat-url="{{ path('poker_planner_heartbeat', {uuid: room.id}) }}"
    data-heartbeat-ms="{{ heartbeat_seconds * 1000 }}"
    data-share-url="{{ shareUrl }}"
    data-show-confetti="{{ room.settings.showConfetti ? '1' : '0' }}"
    data-entry-url="{{ path('poker_planner_entry') }}"
>
    <span id="pp-room-meta" hidden data-show-confetti="{{ room.settings.showConfetti ? '1' : '0' }}" data-celebrate-confetti="0"></span>
    <div class="pp-corner pp-corner--tl">
        {% include '@SymfinityPokerPlanner/_brand.html.twig' with {
            inRoom: true,
            roomTitle: room.settings.displayTitle(),
            showEphemeralMark: self.isModerator and not room.settings.saved,
        } %}
    </div>

    <div class="pp-corner pp-corner--tr">
        <button type="button" class="pp-corner-btn" data-dialog-open="pp-invite-dialog">Invite</button>
        <button type="button" class="pp-corner-btn" data-dialog-open="pp-settings-dialog">Settings</button>
    </div>

    <div class="pp-corner pp-corner--br">
        <button type="button" class="pp-corner-btn pp-corner-btn--icon" data-dialog-open="pp-about-dialog" aria-label="About Poker Planner">@</button>
    </div>

    {% include '@SymfinityPokerPlanner/room/_story_queue.html.twig' with {
        roomId: room.id,
        storyTitle: room.storyTitle,
        storyQueue: storyQueue,
        isModerator: self.isModerator,
    } %}

    <div class="pp-room__canvas">
        <header class="pp-room__header">
            {% include '@SymfinityPokerPlanner/room/_story_title.html.twig' with {
                storyTitle: room.storyTitle,
                storyQueue: storyQueue,
            } %}
        </header>

        <section class="pp-room__stage{% if phase.value == 'revealed' %} pp-room__stage--revealed{% endif %}" aria-label="Estimator slots">
            {% include '@SymfinityPokerPlanner/room/_slot_grid.html.twig' with {participants: participants, phase: phase, consensus: consensus} %}
        </section>

        {% if phase.value == 'revealed' and consensus %}
            {% include '@SymfinityPokerPlanner/room/_consensus_strip.html.twig' with {
                consensus: consensus,
                roundedMedianLabel: roundedMedianLabel,
                celebrateConfetti: room.settings.showConfetti and consensus.hasZeroSpread(),
            } %}
        {% else %}
            <div id="consensus-strip" class="pp-consensus pp-consensus--empty" hidden></div>
        {% endif %}

        {% include '@SymfinityPokerPlanner/room/_vote_deck.html.twig' with {
            roomId: room.id,
            room: room,
            deck: deck,
            phase: phase,
            selectedVote: self.voteValue ? self.voteValue.value : null,
        } %}

        {% if self.isModerator %}
            {% include '@SymfinityPokerPlanner/room/_moderator_actions.html.twig' with {
                roomId: room.id,
                phase: phase,
                storyQueue: storyQueue,
                canRevealQuorum: canRevealQuorum,
                hasAnyVotes: hasAnyVotes,
            } %}
        {% endif %}
    </div>

    {% include '@SymfinityPokerPlanner/room/_invite_dialog.html.twig' with {shareUrl: shareUrl} %}
    {% include '@SymfinityPokerPlanner/room/_settings_dialog.html.twig' with {
        room: room,
        roomId: room.id,
        selfName: self.displayName,
        renameUrl: path('poker_planner_rename', {uuid: room.id}),
        roomParticipants: participants,
        phase: phase,
        recapRows: recapRows,
        deckPresets: deckPresets,
        roundingModes: roundingModes,
        isModerator: self.isModerator,
    } %}
    {% include '@SymfinityPokerPlanner/_about_dialog.html.twig' %}
</main>
{% endblock %}
