<dialog id="pp-invite-dialog" class="pp-dialog">
    <header class="pp-dialog__header">
        <h2 class="pp-dialog__title">Invite</h2>
        <button type="button" class="pp-dialog__close" data-dialog-close aria-label="Close">×</button>
    </header>
    <div class="pp-dialog__body">
        <p class="pp-dialog__lead">Share this link so others can join without a room id.</p>
        <div class="pp-invite-url">
            <label class="pp-sr-only" for="pp-invite-url-field">Invite link</label>
            <input type="text" class="pp-field" id="pp-invite-url-field" readonly value="{{ shareUrl }}" placeholder="Invite link">
            <button type="button" class="pp-corner-btn pp-corner-btn--solid" data-invite-copy>Copy link</button>
        </div>
        <p id="pp-invite-copy-status" class="pp-dialog__hint" aria-live="polite"></p>
        {# TODO: Add QR code component 
        <div class="pp-invite-qr">
            <canvas id="pp-invite-qr-canvas" width="180" height="180" role="img" aria-label="Room QR code"></canvas>
        </div>
        #}
    </div>
</dialog>
