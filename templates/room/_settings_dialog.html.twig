{% set scheme_labels = { auto: 'System', light: 'Light', dark: 'Dark' } %}
{% set canEdit = isModerator|default(false) %}

<dialog id="pp-settings-dialog" class="pp-dialog pp-dialog--wide">
    <header class="pp-dialog__header">
        <h2 class="pp-dialog__title">Settings</h2>
        <button type="button" class="pp-dialog__close" data-dialog-close aria-label="Close">×</button>
    </header>
    <div class="pp-dialog__tabs" role="tablist" aria-label="Settings sections">
        <button type="button" class="pp-dialog__tab is-active" role="tab" aria-selected="true" data-settings-tab="me">Me</button>
        <button type="button" class="pp-dialog__tab" role="tab" aria-selected="false" data-settings-tab="game">Game</button>
        <button type="button" class="pp-dialog__tab" role="tab" aria-selected="false" data-settings-tab="players">Players</button>
        <button type="button" class="pp-dialog__tab" role="tab" aria-selected="false" data-settings-tab="session">Session</button>
        {% if canEdit %}
            <button type="button" class="pp-dialog__tab" role="tab" aria-selected="false" data-settings-tab="room">Room</button>
        {% endif %}
    </div>

    <div class="pp-dialog__body">
        <section class="pp-settings-panel is-active" data-settings-panel="me" role="tabpanel">
            <h3 class="pp-settings-panel__title">Name</h3>
            {% if renameUrl is defined %}
                <form method="post" action="{{ renameUrl }}" class="pp-settings-form" data-settings-rename>
                    <label class="pp-sr-only" for="settings-display-name">Name</label>
                    <input id="settings-display-name" class="pp-field" name="display_name" value="{{ selfName }}" maxlength="64" required placeholder="Your name">
                    <button type="submit" class="pp-corner-btn pp-corner-btn--solid">Save name</button>
                </form>
            {% endif %}

            <h3 class="pp-settings-panel__title">Appearance</h3>
            <div class="pp-scheme-segment" role="group" aria-label="Color scheme">
                {% for link in schemeSwitcherLinks %}
                    <a
                        href="{{ link.url }}"
                        class="pp-scheme-segment__btn{% if link.active %} is-active{% endif %}"
                        {% if link.active %}aria-current="true"{% endif %}
                    >{{ scheme_labels[link.scheme]|default(link.scheme) }}</a>
                {% endfor %}
            </div>
        </section>

        {% include '@SymfinityPokerPlanner/room/_settings_game_panel.html.twig' with {
            room: room,
            deckPresets: deckPresets,
            roundingModes: roundingModes,
            isModerator: isModerator,
        } %}

        <section class="pp-settings-panel" data-settings-panel="players" role="tabpanel" hidden>
            <h3 class="pp-settings-panel__title">Room creator</h3>
            <ul class="pp-players-list">
                {% for participant in roomParticipants %}
                    <li class="pp-players-list__item">
                        <span class="pp-players-list__name">{{ participant.displayName }}{% if participant.isModerator %}*{% endif %}</span>
                        <span class="pp-players-list__status">
                            {% if phase.value == 'revealed' and participant.voteLabel %}
                                {{ participant.voteLabel }}
                            {% elseif participant.hasVoted %}
                                Ready
                            {% else %}
                                Thinking
                            {% endif %}
                        </span>
                    </li>
                {% else %}
                    <li class="pp-players-list__empty">No players yet.</li>
                {% endfor %}
            </ul>
        </section>

        {% include '@SymfinityPokerPlanner/room/_settings_session_panel.html.twig' with {
            recapRows: recapRows|default([]),
        } %}

        {% if canEdit %}
            {% include '@SymfinityPokerPlanner/room/_settings_room_panel.html.twig' with {
                room: room,
                isModerator: isModerator,
            } %}
        {% endif %}
    </div>
</dialog>
