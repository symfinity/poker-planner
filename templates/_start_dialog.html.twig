<dialog
    id="pp-start-dialog"
    class="pp-dialog pp-dialog--wide"
    {% if roomId %}data-default-tab="join" data-auto-open="1"{% endif %}
>
    <header class="pp-dialog__header">
        <h2 class="pp-dialog__title">Session</h2>
        <button type="button" class="pp-dialog__close" data-dialog-close aria-label="Close">×</button>
    </header>
    <div class="pp-dialog__tabs" role="tablist" aria-label="Start or join">
        <button
            type="button"
            class="pp-dialog__tab{% if not roomId %} is-active{% endif %}"
            role="tab"
            aria-selected="{{ roomId ? 'false' : 'true' }}"
            data-entry-tab="start"
        >Start a new session</button>
        <button
            type="button"
            class="pp-dialog__tab{% if roomId %} is-active{% endif %}"
            role="tab"
            aria-selected="{{ roomId ? 'true' : 'false' }}"
            data-entry-tab="join"
        >Join with a room link or id manually</button>
    </div>
    <div class="pp-dialog__body">
        {% for message in app.flashes('warning') %}
            <p class="pp-flash pp-flash--warning" role="status">{{ message }}</p>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <p class="pp-flash pp-flash--error" role="alert">{{ message }}</p>
        {% endfor %}

        <section class="pp-entry-panel{% if not roomId %} is-active{% endif %}" data-entry-panel="start" role="tabpanel"{% if roomId %} hidden{% endif %}>
            <form method="post" action="{{ path('poker_planner_create') }}" class="pp-entry-form">
                <label for="create-name">Your name</label>
                <input id="create-name" class="pp-field" name="display_name" required maxlength="64" autocomplete="nickname" autofocus placeholder="Your name">
                <button type="submit" class="pp-corner-btn pp-corner-btn--solid">Start session</button>
            </form>
        </section>

        <section class="pp-entry-panel{% if roomId %} is-active{% endif %}" data-entry-panel="join" role="tabpanel"{% if not roomId %} hidden{% endif %}>
            <form method="post" action="{{ path('poker_planner_join') }}" class="pp-entry-form">
                <label for="join-name">Your name</label>
                <input id="join-name" class="pp-field" name="display_name" required maxlength="64" autocomplete="nickname" placeholder="Your name"{% if roomId %} autofocus{% endif %}>
                <label for="join-room-id">Room id or share URL</label>
                <input
                    id="join-room-id"
                    class="pp-field"
                    name="room_id"
                    required
                    placeholder="Room id or share URL"
                    value="{{ roomId|default('')|e('html_attr') }}"
                >
                <button type="submit" class="pp-corner-btn pp-corner-btn--solid">Join session</button>
            </form>
        </section>
    </div>
</dialog>
