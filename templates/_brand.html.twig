<a href="{{ path('poker_planner_entry') }}" class="pp-brand" id="pp-brand">
    <span class="pp-brand__icon" aria-hidden="true">{{ ux_blocks_icon('hugeicons:joker') }}</span>
    <span class="pp-brand__title">Poker Planner</span>
    {% if inRoom|default(false) %}
        <span class="pp-brand__suffix" id="pp-brand-suffix">
            <span id="pp-brand-room-title">{{ roomTitle|default('quick room') }}</span>{% if showEphemeralMark|default(false) %}<span class="pp-brand__ephemeral" id="pp-brand-ephemeral" aria-label="Unsaved room">*</span>{% endif %}
        </span>
    {% endif %}
</a>
