{
    "name": "symfinity/poker-planner",
    "description": "Realtime planning-poker rooms with Mercure sync and hidden votes until reveal",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "symfony-bundle",
        "planning-poker",
        "estimation",
        "mercure",
        "agile",
        "scrum"
    ],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "symfinity/ui-kernel": "@dev",
        "symfinity/ux-blocks": "@dev",
        "symfinity/ux-blocks-core": "@dev",
        "symfony/config": "^6.4||^7.0||^8.0",
        "symfony/dependency-injection": "^6.4||^7.0||^8.0",
        "symfony/framework-bundle": "^6.4||^7.0||^8.0",
        "symfony/http-foundation": "^6.4||^7.0||^8.0",
        "symfony/http-kernel": "^6.4||^7.0||^8.0",
        "symfony/mercure-bundle": "^0.3||^0.4",
        "symfony/routing": "^6.4||^7.0||^8.0",
        "symfony/stimulus-bundle": "^2.0||^3.0",
        "symfony/twig-bundle": "^6.4||^7.0||^8.0",
        "symfony/uid": "^6.4||^7.0||^8.0",
        "symfony/ux-turbo": "^2.0||^3.0",
        "symfony/ux-twig-component": "^2.0||^3.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5||^11.0",
        "symfony/asset-mapper": "^6.4||^7.0||^8.0",
        "symfony/browser-kit": "^6.4||^7.0||^8.0",
        "symfony/css-selector": "^6.4||^7.0||^8.0",
        "symfony/yaml": "^6.4||^7.0||^8.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ui-kernel",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks-core",
            "options": { "symlink": true }
        }
    ],
    "autoload": {
        "psr-4": {
            "Symfinity\\Bundle\\PokerPlanner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\Bundle\\PokerPlanner\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist"
    },
    "suggest": {
        "ext-redis": "Native Redis extension (recommended for production)",
        "predis/predis": "Pure-PHP Redis client for dev/dogfood when ext-redis is unavailable"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "0.1.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^6.4||^7.0||^8.0"
        }
    }
}
